<!doctype html>
<html>
<head><link rel="stylesheet" href="/styles.css"></head>
<body>
  <h1>LevelUp</h1>

  <% if (!isAuthenticated) { %>
    <p><a href="/auth/login">Login</a> | <a href="/auth/register">Register</a></p>
  <% } else { %>
    <p>Welcome, <%= username %> | <form method="POST" action="/auth/logout" style="display:inline">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button>Logout</button>
    </form></p>

    <p><a href="/quests">My Quests</a></p>
  <% } %>
</body>
</html>