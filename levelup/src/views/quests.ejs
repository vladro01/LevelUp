<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LevelUp – My Quests</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

    <nav class="navbar">
        <span class="nav-brand">⚡ LevelUp</span>
        <div class="nav-links">
          <a href="/">Dashboard</a>
          <a href="/quests">Quests</a>
          <a href="/quests/logs">My Logs</a>
          <% if (isAuthenticated) { %>
            <a href="/shop">Shop</a>
            <a href="/avatar">My Avatar</a>
            <span class="nav-user">Welcome, <strong><%= username %></strong></span>
            <form method="POST" action="/auth/logout" style="display:inline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="btn btn-sm btn-outline">Logout</button>
            </form>
          <% } else { %>
            <a href="/auth/login" class="btn btn-sm">Login</a>
            <a href="/auth/register" class="btn btn-sm btn-outline">Register</a>
          <% } %>
        </div>
      </nav>

  <main class="container">

    <% if (typeof query !== 'undefined') { %>
      <% if (query.created)   { %><p class="flash flash-success">✅ Quest created!</p><% } %>
      <% if (query.updated)   { %><p class="flash flash-success">✅ Quest updated!</p><% } %>
      <% if (query.deleted)   { %><p class="flash flash-danger">🗑 Quest deleted.</p><% } %>
      <% if (query.toggled)   { %><p class="flash flash-info">Quest status updated.</p><% } %>
      <% if (query.completed) { %><p class="flash flash-success">✅ Quest completed! XP awarded.</p><% } %>
    <% } %>

    <section class="panel">
      <h2 class="panel-title">➕ Create New Quest</h2>

      <% if (errors.length) { %>
        <ul class="error-list">
          <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
        </ul>
      <% } %>

      <form method="POST" action="/quests" class="quest-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-row">
          <input class="form-input" name="title" placeholder="Quest title (e.g. Morning Run)"
                 value="<%= values.title || '' %>" required>
          <select class="form-select" name="difficulty">
            <option value="easy"   <%= values.difficulty==='easy'  ?'selected':'' %>>Easy (+10 XP)</option>
            <option value="medium" <%= values.difficulty==='medium'?'selected':'' %>>Medium (+20 XP)</option>
            <option value="hard"   <%= values.difficulty==='hard'  ?'selected':'' %>>Hard (+30 XP)</option>
          </select>
          <button class="btn">Create Quest</button>
        </div>
      </form>
    </section>

    <section class="panel">
      <h2 class="panel-title">⚔️ Your Quests</h2>

      <% if (!quests.length) { %>
        <p class="empty-state">No quests yet. Create one above to get started!</p>
      <% } else { %>
        <ul class="quest-list">
          <% quests.forEach(q => { %>
            <li class="quest-item <%= !q.is_active ? 'quest-item-paused' : '' %>">
              <div class="quest-info">
                <span class="quest-title"><%= q.title %></span>
                <span class="badge badge-<%= q.difficulty %>"><%= q.difficulty %></span>
                <% if (!q.is_active) { %><span class="badge badge-paused">Paused</span><% } %>
              </div>
              <div class="quest-actions">
                <% if (q.is_active) { %>
                  <form method="POST" action="/quests/<%= q.id %>/complete" style="display:inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn btn-sm btn-success">✓ Complete</button>
                  </form>
                <% } %>
                <a href="/quests/<%= q.id %>/edit" class="btn btn-sm btn-outline">Edit</a>
                <form method="POST" action="/quests/<%= q.id %>/toggle" style="display:inline">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="btn btn-sm btn-outline"><%= q.is_active ? '⏸ Pause' : '▶ Resume' %></button>
                </form>
                <form method="POST" action="/quests/<%= q.id %>/delete" style="display:inline"
                      onsubmit="return confirm('Delete this quest and all its logs?')">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="btn btn-sm btn-danger">🗑</button>
                </form>
              </div>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </section>

    <div class="quick-links">
      <a href="/" class="btn btn-outline">← Dashboard</a>
      <a href="/quests/logs" class="btn btn-outline">View Logs</a>
    </div>

  </main>
</body>
</html>