<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LevelUp – Sign In</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

  <nav class="navbar">
    <span class="nav-brand">⚡ LevelUp</span>
  </nav>

  <main class="container">
    <div class="auth-card">
      <h1>Sign in</h1>
      <p style="color: var(--text-muted); font-size:0.9rem; margin-bottom:1.5rem">
        Log in to track your quests and see your progress.
      </p>

      <% if (error) { %>
        <p class="flash flash-danger"><%= error %></p>
      <% } %>

      <form method="POST" action="/auth/login">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label class="form-label">Email</label>
          <input class="form-input" name="email" type="email"
                 value="<%= values.email || '' %>" required autocomplete="email">
        </div>
        <div class="form-group">
          <label class="form-label">Password</label>
          <input class="form-input" name="password" type="password" required autocomplete="current-password">
        </div>
        <button class="btn" style="width:100%; margin-top:0.5rem">Sign in</button>
      </form>

      <p class="auth-footer">New here? <a href="/auth/register">Create an account</a></p>
    </div>
  </main>

</body>
</html>