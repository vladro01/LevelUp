<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LevelUp – Edit Quest</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

  <nav class="navbar">
    <span class="nav-brand">⚡ LevelUp</span>
    <div class="nav-links">
      <a href="/">Dashboard</a>
      <a href="/quests" class="active">Quests</a>
      <a href="/quests/logs">My Logs</a>
      <span class="nav-user">Welcome, <strong><%= username %></strong></span>
      <form method="POST" action="/auth/logout" style="display:inline">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button class="btn btn-sm btn-outline">Logout</button>
      </form>
    </div>
  </nav>

  <main class="container">
    <section class="panel" style="max-width:480px; margin: 2rem auto;">
      <h2 class="panel-title">✏️ Edit Quest</h2>

      <% if (errors.length) { %>
        <ul class="error-list">
          <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
        </ul>
      <% } %>

      <form method="POST" action="/quests/<%= quest.id %>/edit">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label class="form-label">Quest Title</label>
          <input class="form-input" name="title" value="<%= quest.title %>" required minlength="3" maxlength="120">
        </div>
        <div class="form-group">
          <label class="form-label">Difficulty</label>
          <select class="form-select" name="difficulty">
            <option value="easy"   <%= quest.difficulty==='easy'  ?'selected':'' %>>Easy (+10 XP)</option>
            <option value="medium" <%= quest.difficulty==='medium'?'selected':'' %>>Medium (+20 XP)</option>
            <option value="hard"   <%= quest.difficulty==='hard'  ?'selected':'' %>>Hard (+30 XP)</option>
          </select>
        </div>
        <div class="form-actions">
          <button class="btn">Save Changes</button>
          <a href="/quests" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </section>
  </main>

</body>
</html>